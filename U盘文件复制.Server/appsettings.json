{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "U盘文件复制.Server": "Debug"
    }
  },
  "AllowedHosts": "*",

  // ===== CORS 配置 =====
  "Cors": {
    // 允许的源列表，生产环境应设为具体域名
    // 使用 "*" 表示允许所有源（仅推荐开发环境使用）
    "AllowedOrigins": [ "*" ]
  },

  // ===== 文件存储配置 =====
  "FileStorage": {
    // 文件存储根目录（绝对或相对路径，相对于程序运行目录）
    "RootPath": "Storage",
    // 分块上传临时目录（相对于 RootPath）
    "TempChunkFolder": "_chunks",
    // 单个文件最大大小（字节），默认 1GB
    "MaxFileSizeBytes": 1073741824,
    // 允许的令牌列表（支持多个客户端）
    // ⚠️ 生产环境请修改为强随机令牌
    "AllowedTokens": [
      "1145141919810"
    ]
  }
}
